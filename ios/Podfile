# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'StarStoneCollectionGuide' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # fmt 11.0.2 can fail to compile with newer Apple clang versions during archive.
    # Disable its consteval path until React Native ships the upstream fmt bump.
    fmt_base_header = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base_header)
      contents = File.read(fmt_base_header)
      patched_contents = contents
        .gsub("#elif defined(__cpp_consteval)\n#  define FMT_USE_CONSTEVAL 1",
              "#elif defined(__cpp_consteval)\n#  define FMT_USE_CONSTEVAL 0")
        .gsub("#elif FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101\n#  define FMT_USE_CONSTEVAL 1",
              "#elif FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101\n#  define FMT_USE_CONSTEVAL 0")

      if patched_contents != contents
        File.chmod(File.stat(fmt_base_header).mode | 0o200, fmt_base_header)
        File.write(fmt_base_header, patched_contents)
        Pod::UI.puts 'Patched fmt 11.0.2 consteval checks for Apple clang compatibility'
      end
    end
  end
end
